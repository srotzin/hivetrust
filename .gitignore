# ─────────────────────────────────────────────────────────────────────────────
# HiveTrust .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# Dependencies
node_modules/
.pnp
.pnp.js

# Environment & secrets
.env
.env.local
.env.*.local
*.pem
*.key

# Database files
data/*.db
data/*.db-shm
data/*.db-wal
data/*.sqlite
data/*.sqlite3

# Build output
dist/
build/
out/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# OS artefacts
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Editor directories
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Test coverage
coverage/
.nyc_output/

# TypeScript cache
*.tsbuildinfo

# Optional REPL history
.node_repl_history

# Yarn v2+
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*
