# ─────────────────────────────────────────────────────────────────────────────
# HiveTrust Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────

# TCP port the server listens on (default: 3001 — distinct from HiveAgent's 3000)
PORT=3001

# Node environment: development | production | test
NODE_ENV=development

# Public base URL of this HiveTrust instance (used in issued credentials and links)
HIVETRUST_HOST=https://hivetrust.hiveagentiq.com

# ── Security ─────────────────────────────────────────────────────────────────

# Shared secret for internal service-to-service calls (HiveAgent ↔ HiveTrust)
# Generate with: openssl rand -hex 32
INTERNAL_API_TOKEN=change_me_generate_with_openssl_rand_hex_32

# Secret used to sign outgoing webhook payloads (HMAC-SHA256)
# Generate with: openssl rand -hex 32
WEBHOOK_SIGNING_SECRET=change_me_generate_with_openssl_rand_hex_32

# ── Cross-platform Integration ────────────────────────────────────────────────

# Base URL of the companion HiveAgent platform
HIVEAGENT_URL=https://hiveagentiq.com

# ── Coinbase CDP (USDC collateral & on-chain settlement) ──────────────────────

# Coinbase Developer Platform API credentials
# Obtain at: https://portal.cdp.coinbase.com
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# Address of the USDC collateral pool smart contract on Base L2
# Deployed during initial platform setup
COLLATERAL_POOL_ADDRESS=

# Base L2 RPC endpoint (default: Coinbase-hosted public node)
BASE_RPC_URL=https://mainnet.base.org

# ── Database ─────────────────────────────────────────────────────────────────

# Path to the SQLite database file (WAL mode, foreign keys enabled)
# Default: data/hivetrust.db  (relative to project root)
DB_PATH=data/hivetrust.db

# ── Federation ───────────────────────────────────────────────────────────────

# Shared secret used to authenticate federation sync requests from peer registries
# Generate with: openssl rand -hex 32
FEDERATION_SECRET=change_me_generate_with_openssl_rand_hex_32

# Comma-separated list of trusted federation peer base URLs
# Example: https://registry.example.com,https://trust.another.example
FEDERATION_PEERS=

# ── Trust Scoring ─────────────────────────────────────────────────────────────

# How often (in minutes) background score recomputation runs
SCORE_REFRESH_INTERVAL_MINUTES=60

# Minimum trust score required for insurance eligibility (default: 300)
INSURANCE_MIN_SCORE=300

# ── Insurance Underwriting ────────────────────────────────────────────────────

# Maximum single-transaction coverage in USDC
INSURANCE_MAX_COVERAGE_USDC=100000

# Base premium rate (as a decimal fraction of transaction value, default: 0.015 = 1.5%)
INSURANCE_BASE_RATE=0.015

# ── Observability ─────────────────────────────────────────────────────────────

# Log level: error | warn | info | debug
LOG_LEVEL=info

# Optional: send structured logs to a remote sink
# LOG_DRAIN_URL=https://logs.example.com/ingest
